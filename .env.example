# LearnAI Environment Configuration Example
# Copy this file to '.env.local' and set the default API key to share with friends.

# The default API key to use when the user hasn't configured their own key in the UI.
# Supports Groq (gsk_...), Gemini (AIzaSy...), OpenRouter (sk-or-...), or OpenAI (sk-...).
NEXT_PUBLIC_DEFAULT_API_KEY=your_shared_api_key_here
